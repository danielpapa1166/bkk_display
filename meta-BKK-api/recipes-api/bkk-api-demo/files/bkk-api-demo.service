[Unit]
Description=BKK API demo application
After=network-online.target bkk-api-keygen.service
Wants=network-online.target
Requires=bkk-api-keygen.service

[Service]
Type=oneshot
EnvironmentFile=/etc/environment.d/10-bkk-api.conf
ExecStart=/usr/bin/bkk-api-demo

[Install]
WantedBy=multi-user.target
